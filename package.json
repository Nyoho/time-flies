{
  "name": "time-flies",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.5",
    "react-icons": "^5.5.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
